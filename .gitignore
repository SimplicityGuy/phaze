# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ML models (downloaded via scripts/download-models.sh). Ignore the CONTENTS
# (models/*) rather than the dir itself so the committed models/.gitkeep can be
# re-included — git cannot re-include a file whose parent DIRECTORY is excluded.
models/*
# phaze-he8m: keep the ./models/ mount-point dir tracked (via .gitkeep) so a git
# clone materializes it owned by the operator (uid 1000) instead of dockerd
# auto-creating it root:root — the downloaded weights themselves stay ignored.
!models/.gitkeep
# ...but the source package src/phaze/models/ is real code, not downloaded artifacts.
!src/phaze/models/

# Claude Code worktrees
.claude/

# Update script backups
.backups/

# graphify cache
graphify-out/cache/

# graphify HTML viz — unbuildable past graphify's node cap (the graph is too large
# for the HTML viz), so it can only ever be a stale artifact. The queryable graph.json
# + GRAPH_REPORT.md are the source of truth; don't track the viz.
graphify-out/graph.html
.planning/graphs/graph.html

# Vim
*.swp
.superpowers/
.playwright-mcp/

# Build-time Tailwind: the standalone binary and the generated stylesheet are
# produced by `just tailwind` (local) / the Dockerfile css-builder stage (image),
# never committed. Source of truth is assets/src/app.css.
/bin/
src/phaze/static/css/app.css

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# bv (beads viewer) local config and caches
.bv/

# beads issue tracker — local Dolt-backed store, not versioned in git
.beads/

# Local repowise index/tool state -- not project source.
.repowise/

# Claude Code MCP server config (local, machine-specific) + VS Code workspace settings
.mcp.json
.vscode/
