# =====================================================================
# Phaze .env example
#
# Host vs Container
# -----------------
# DATABASE_URL, PHAZE_QUEUE_URL, and REDIS_URL below use the DOCKER SERVICE
# NAMES `postgres` and `redis`. That's correct when the api/worker/watcher run
# via `docker compose up`. If you instead run any service directly on the
# HOST via `uv run`, switch to:
#   DATABASE_URL=postgresql+asyncpg://phaze:phaze@localhost:5432/phaze
#   PHAZE_QUEUE_URL=postgresql://phaze:phaze@localhost:5432/phaze
#   REDIS_URL=redis://localhost:6379/0
# (or use an SSH tunnel to the remote home server).
# =====================================================================

# =====================================================================
# Secrets via files (`_FILE` convention)
# =====================================================================
# Every secret-bearing variable below (DATABASE_URL, PHAZE_QUEUE_URL, REDIS_URL,
# OPENAI_API_KEY, ANTHROPIC_API_KEY, PHAZE_AGENT_TOKEN) also accepts a
# `<VAR>_FILE` sibling pointing at a file that holds the value -- e.g. a
# Docker/Swarm secret (/run/secrets/...), a Kubernetes secret mount, or a
# SOPS-decrypted file. If both are set, the direct env var wins. The file's
# trailing newline / surrounding whitespace is stripped. A `_FILE` path that
# is missing or unreadable fails fast at startup (no silent empty fallback).
# Example:
#   DATABASE_URL_FILE=/run/secrets/phaze_database_url

# Database
DATABASE_URL=postgresql+asyncpg://phaze:phaze@postgres:5432/phaze
# DATABASE_URL_FILE=/run/secrets/phaze_database_url
POSTGRES_USER=phaze
# phaze-rnh7: docker-compose.yml now requires POSTGRES_PASSWORD (fail-fast `${VAR:?}`)
# exactly like REDIS_PASSWORD — no weak silent default. Fresh dev clones may keep the
# placeholder; production MUST set a strong unique value (and update DATABASE_URL /
# PHAZE_QUEUE_URL to match).
POSTGRES_PASSWORD=phaze
POSTGRES_DB=phaze
# phaze-rnh7: interface to bind the published postgres :5432 on. Dev = loopback.
# Production = the app-server's LAN IP (e.g. 192.168.1.10) so agents on other hosts
# reach it — mirrors REDIS_BIND_IP. WITHOUT an IP prefix docker binds 0.0.0.0 (whole LAN).
POSTGRES_BIND_IP=127.0.0.1

# SAQ queue broker (Postgres — Phase 36). MUST be the raw libpq form
# (`postgresql://`), NOT the SQLAlchemy `postgresql+asyncpg://` dialect:
# psycopg3's pool cannot parse the `+driver` suffix. Carries DB credentials,
# so prefer the `_FILE` secret. On agent hosts this points at the app-server
# Postgres LAN IP:5432 (agents open a psycopg3 pool to it — new firewall edge).
PHAZE_QUEUE_URL=postgresql://phaze:phaze@postgres:5432/phaze
# PHAZE_QUEUE_URL_FILE=/run/secrets/phaze_queue_url

# Redis (cache / rate-limit / counters only — no longer the SAQ broker)
# phaze-hti8: Redis runs with `--requirepass ${REDIS_PASSWORD}`, so clients MUST
# authenticate. Under docker compose, the api + worker services OVERRIDE this value
# via their `environment:` block with `redis://default:${REDIS_PASSWORD}@redis:6379/0`
# (compose interpolates; env_file does not), so the app always gets an authenticated
# URL. This passwordless form is only the fallback for non-docker local runs against a
# passwordless Redis. For a non-docker run against a requirepass Redis, set the
# authenticated form here explicitly: redis://default:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=redis://redis:6379/0
# REDIS_URL_FILE=/run/secrets/phaze_redis_url

# Application
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# =====================================================================
# Phase 29: Redis hardening (D-05)
# =====================================================================
# Required password for redis-server --requirepass. Fresh dev clones can
# use the placeholder; production MUST set a strong unique value.
REDIS_PASSWORD=changeme
# Interface to bind redis :6379 on. Dev = loopback. Production = LAN IP
# (e.g., 192.168.1.10) so agents on other hosts can reach it.
REDIS_BIND_IP=127.0.0.1

# =====================================================================
# Phase 29: HTTPS via internal CA (D-02)
# =====================================================================
# Comma-separated SAN list for the auto-generated leaf cert. Defaults
# include `api` (docker compose service-name DNS) for single-host dev.
# Production should add the app-server's LAN hostname / IP.
PHAZE_API_TLS_SANS=localhost,127.0.0.1,api

# File discovery - mounted music directory for scanning
SCAN_PATH=/data/music

# =====================================================================
# Bring-up (Phase 27 UAT Gap 2 / Gap 3)
# =====================================================================
# Run alembic upgrade head in the api lifespan on every startup.
# Set to false in production environments where you want to gate
# migrations behind a manual maintenance window.
# PHAZE_AUTO_MIGRATE=true
#
# On a fresh agents table, seed a single dev-agent row so the watcher
# can authenticate on first start. Production deployments should keep
# this `false` (default) and provision agents via the management CLI.
# PHAZE_DEV_SEED_AGENT=false
#
# Optional fixed bearer for the dev-seeded agent. If unset, the api
# generates a random one and logs it at INFO -- scrape it from
# `docker compose logs api` and paste into PHAZE_AGENT_TOKEN below.
# Format: phaze_agent_<32 urlsafe-base64 bytes>.
# PHAZE_DEV_AGENT_TOKEN=

# =====================================================================
# Agent Mode (required when PHAZE_ROLE=agent)
# =====================================================================
# The watcher container runs with PHAZE_ROLE=agent and needs all three:
#
# 1. URL of the application server. When running in docker compose:
#    http://api:8000 (service DNS). When running on the host:
#    http://localhost:8000 or your tunnel URL.
# PHAZE_AGENT_API_URL=http://api:8000
#
# 2. Bearer issued at agent registration. MUST match the sha256(token_hash)
#    stored in the `agents` table for the calling agent. For dev bring-up
#    on a fresh DB, copy the token logged by `docker compose logs api`
#    after PHAZE_DEV_SEED_AGENT=true triggers ensure_dev_agent. Format:
#    phaze_agent_<32 urlsafe-base64 bytes>.
# PHAZE_AGENT_TOKEN=
#    Or load it from a mounted secret file (newline stripped so the hash matches):
# PHAZE_AGENT_TOKEN_FILE=/run/secrets/phaze_agent_token
#
# 3. Comma-separated list of absolute filesystem paths the agent is
#    permitted to read/write. Used by execute_approved_batch for path-
#    traversal containment.
# PHAZE_AGENT_SCAN_ROOTS=/data/music

# =====================================================================
# Watcher tunables (optional -- defaults shown below)
# =====================================================================
# Seconds a file's mtime must be stable before the watcher posts it (D-01)
# PHAZE_WATCHER_SETTLE_SECONDS=10
# Stuck-file cap: entries older than this are evicted from the pending set (D-02)
# PHAZE_WATCHER_MAX_PENDING_SECONDS=3600
# How often the watcher's sweep task checks for settled files (D-01)
# PHAZE_WATCHER_SWEEP_INTERVAL_SECONDS=2
# Use watchdog's PollingObserver instead of native inotify. REQUIRED on macOS
# docker bind mounts (rancher-desktop / Docker Desktop) where inotify events
# do not propagate through 9p/virtiofs. Leave false in production Linux
# deployments where inotify works natively.
# PHAZE_WATCHER_POLLING_MODE=false
# Number of FileUpsertRecord rows per chunk in scan_directory (D-11)
# PHAZE_SCAN_CHUNK_SIZE=500
# RUNNING scans that make no progress for this many seconds are auto-failed as
# "stalled" by the control worker's every-minute reaper cron. The admin UI warns
# (amber "stalled?") at half this threshold, before the hard reap.
# PHAZE_SCAN_STALL_SECONDS=600

# =====================================================================
# Logging / observability (all roles)
# =====================================================================
# Root log level: DEBUG | INFO | WARNING | ERROR (default INFO). Set DEBUG to
# watch a running scan or model download in detail (per-file events).
# PHAZE_LOG_LEVEL=INFO
# Output format: true = JSON (one object per line), false = console. Unset =
# auto (JSON when stdout is not a TTY, e.g. under Docker; console otherwise).
# PHAZE_LOG_JSON=true

# Docker (for volume permissions)
UID=1000
GID=1000

# Audio analysis models -- host directory mounted into worker container
# Run 'just download-models' to populate, then set path here
MODELS_PATH=./models

# =====================================================================
# LLM API keys (control role -- required only for the provider you use)
# =====================================================================
# Both accept a `_FILE` sibling (e.g. a mounted Docker secret) instead of
# inlining the cleartext key.
# OPENAI_API_KEY=
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key

# =====================================================================
# Backend registry (control role -- ControlSettings)
# =====================================================================
# >>> BREAKING REMOVAL IN 2026.7.1 <<<  The old flat cloud-target selector and
# the flat per-target env vars are REMOVED with NO back-compat shim:
#   * the single cloud-target selector (the local/a1/k8s string)
#   * the control-side compute scratch-dir mirror
#   * the flat kube client vars (api url / namespace / local-queue / kubeconfig /
#     SA token)
#   * the flat S3 connection/credential vars (bucket / endpoint / region /
#     addressing-style / access-key / secret-key)
# If any of these are still set in your live homelab env they are now IGNORED.
# ACTION REQUIRED: delete them from your .env and describe your backends in a
# backends.toml file instead (see below).
#
# The typed backend registry is now the SOLE cloud config surface. It is loaded
# from a TOML file pointed at by PHAZE_BACKENDS_CONFIG_FILE. If the file is
# ABSENT the control plane defaults to an implicit single kind=local backend --
# an all-local deploy needs ZERO config edits (zero-config default). Point the
# var at your file to enable compute / Kueue backends:
# PHAZE_BACKENDS_CONFIG_FILE=/etc/phaze/backends.toml
#
# The backends.toml schema (array-of-tables: [[backends]] with id/kind/rank/cap
# + per-kind connection config and inline `*_file` secrets; [[buckets]] with
# id/scope/endpoint/creds) is documented in docs/configuration.md. This is a
# CONTROL-PLANE-ONLY surface; it does NOT belong on any agent host.
#
# --- Kept GLOBAL tuning knobs (control role; NOT per-backend, still env vars) ---
# Duration (seconds) at/above which a file is routed to a cloud backend:
# PHAZE_CLOUD_ROUTE_THRESHOLD_SEC=5400
# Retry budgets before a file is marked ANALYSIS_FAILED:
# PHAZE_PUSH_MAX_ATTEMPTS=3
# PHAZE_CLOUD_SUBMIT_MAX_ATTEMPTS=3
# Global S3 presign / lifecycle / multipart knobs (apply to every bucket):
# PHAZE_S3_PRESIGN_PUT_TTL_SEC=3600
# PHAZE_S3_PRESIGN_GET_TTL_SEC=900
# PHAZE_S3_LIFECYCLE_TTL_DAYS=2
# PHAZE_S3_MULTIPART_PART_SIZE_BYTES=67108864
